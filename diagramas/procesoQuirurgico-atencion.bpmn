    <textAnnotation id="Id_ed95e547-b043-439a-8e24-9242ec328916">
      <documentation />
      <extensionElements>
        <bizagi:BizagiExtensions xmlns:bizagi="http://www.bizagi.com/bpmn20">
          <bizagi:BizagiProperties>
            <bizagi:BizagiProperty name="bgColor" value="#D5D5D5" />
            <bizagi:BizagiProperty name="borderColor" value="#D5D5D5" />
            <bizagi:BizagiProperty name="textColor" value="#000000" />
            <bizagi:BizagiProperty name="textBackgroundColor" value="#FFFFFF" />
            <bizagi:BizagiProperty name="textDirection" value="" />
          </bizagi:BizagiProperties>
        </bizagi:BizagiExtensions>
      </extensionElements>
      <text>Se debe enviar el ID de indicación creada por el script de integración y el ID de paciente</text>
    </textAnnotation>
    <textAnnotation id="Id_0d889b77-2ac8-462b-8c2b-dbe4e980e0dc">
      <documentation />
      <extensionElements>
        <bizagi:BizagiExtensions xmlns:bizagi="http://www.bizagi.com/bpmn20">
          <bizagi:BizagiProperties>
            <bizagi:BizagiProperty name="bgColor" value="#D5D5D5" />
            <bizagi:BizagiProperty name="borderColor" value="#D5D5D5" />
            <bizagi:BizagiProperty name="textColor" value="#000000" />
            <bizagi:BizagiProperty name="textBackgroundColor" value="#FFFFFF" />
            <bizagi:BizagiProperty name="textDirection" value="" />
          </bizagi:BizagiProperties>
        </bizagi:BizagiExtensions>
      </extensionElements>
      <text>Se debe trasladar al paciente si se quiere envíar a urgencia u hospitalización. Actualmente el cupo se debe liberar manualmente solo en hospitalización</text>
    </textAnnotation>
