        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n  direction LR\n\n  class AtencionQuirurgica {\n    +patient: Patient\n    +datosIntervenciones: DatosIntervenciones\n    +datosEvaluaciones: DatosEvaluaciones\n    +pausasQuirurgicas: PausasQuirurgicas\n    +state: EstadoBase\n    +service\n    +externalReference\n    +origenCarga\n    +datosCreacion\n    +tabla\n    +programacion\n    +ubicacion\n    +especialidad\n    +extendedData\n    +esCma\n    +responsable\n    +patientService\n    +crmId\n    +seRealizoEvaluacionPreAnestesica\n    +seRealizoProtocoloQx\n    +loadLocationHLTH(location)\n    +adaptFromPatientService(patientService, plugin)\n    +adaptFromIndication(indication, plugin)\n    +adaptFromAppointment(appointment, plugin)\n  }\n\n  class Patient {\n    +id\n    +nin\n    +genre\n    +socialname\n    +firstname\n    +secondname\n    +lastname\n    +lastnameTwo\n    +birthdate\n    +healthBenefits\n    +fullname()\n    +getFullName\n    +age\n    +loadHLTHRaw(raw)\n    +loadAgendaRaw(raw)\n    +toJSON()\n  }\n\n  class EstadoBase {\n    +atencionQuirurgica: AtencionQuirurgica\n    +maxExposedActions\n    +id\n    +description\n    +text\n    +textClass\n    +key\n    +toJSON()\n    +nombreHito\n    +setActions(actions)\n    +getActionsMap()\n    +setRegistroAcciones(registro)\n  }\n\n  class DatosIntervenciones {\n    +intervenciones\n    +diagnosticos\n    +tiempoOperatorio\n    +loadFromRaw(raw)\n  }\n\n  class DatosEvaluaciones {\n    +evaluaciones\n    +adaptFromHLTHRaw(evaluacionesRaw)\n    +tieneEvaluacionDeTipo(tipoEvaluacionId)\n  }\n\n  class PausasQuirurgicas {\n    +pausas\n  }\n\n  AtencionQuirurgica *-- Patient : patient\n  AtencionQuirurgica *-- DatosIntervenciones : datosIntervenciones\n  AtencionQuirurgica *-- DatosEvaluaciones : datosEvaluaciones\n  AtencionQuirurgica *-- PausasQuirurgicas : pausasQuirurgicas\n  AtencionQuirurgica *-- EstadoBase : state\n  EstadoBase --&gt; AtencionQuirurgica : contexto\n  PausasQuirurgicas ..&gt; DatosEvaluaciones : se construye desde\n&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="62">
